# Database Configuration
POSTGRES_DB=berit
ODOO_DB=berit_odoo
PORTAL_DB=berit_portal
POSTGRES_USER=berit_user
POSTGRES_PASSWORD=strong_password_here
POSTGRES_HOST=db

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Django Configuration
SECRET_KEY=your-django-secret-key-here-min-50-characters-long
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourDomain.com

# Odoo Configuration
ODOO_MASTER_PASSWORD=your_odoo_master_password_here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=beritfinance@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Berit Shalvah Financial Services <beritfinance@gmail.com>

# Portal Configuration
PORTAL_BASE_URL=http://localhost:8000/portal
COMPANY_NAME=Berit Shalvah Financial Services Ltd
COMPANY_ADDRESS=Kiambu County, Kenya
COMPANY_PHONE=+254-XXX-XXX-XXX
COMPANY_EMAIL=beritfinance@gmail.com

# File Upload Configuration
MAX_UPLOAD_SIZE=20971520  # 20MB in bytes
ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png,doc,docx

# Security Configuration
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging Configuration
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
ODOO_LOG_LEVEL=INFO

# Backup Configuration
BACKUP_RETENTION_DAYS=30
S3_BUCKET=berit-backups
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_REGION=us-east-1

# Development/Production Flags
IS_PRODUCTION=False
SENTRY_DSN=

# Rate Limiting
RATELIMIT_ENABLE=False
RATELIMIT_USE_CACHE=redis

# Webhook Configuration (Real-time Odoo Sync)
ODOO_WEBHOOK_URL=http://localhost:8000/api/webhooks/odoo/
ODOO_WEBHOOK_SECRET=your-webhook-secret-key-here
