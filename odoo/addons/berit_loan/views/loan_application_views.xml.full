<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Loan Application Form View -->
    <record id="view_berit_loan_application_form" model="ir.ui.view">
        <field name="name">berit.loan.application.form</field>
        <field name="model">berit.loan.application</field>
        <field name="arch" type="xml">
            <form string="Loan Application">
                <header>
                    <button name="action_submit" string="Submit" type="object" states="draft" class="btn-primary"/>
                    <button name="action_under_review" string="Start Review" type="object" states="submitted" class="btn-secondary"/>
                    <button name="action_approve" string="Approve" type="object" states="under_review" class="btn-success" groups="berit_loan_manager"/>
                    <button name="action_reject" string="Reject" type="object" states="under_review" class="btn-danger" groups="berit_loan_manager"/>
                    <button name="action_disburse" string="Disburse" type="object" states="approved" class="btn-primary" groups="berit_loan_manager"/>
                    <button name="action_activate" string="Activate" type="object" states="disbursed" class="btn-primary" groups="berit_loan_manager"/>
                    <button name="action_close" string="Close" type="object" states="active" class="btn-success" groups="berit_loan_manager"/>
                    <button name="action_default" string="Mark Defaulted" type="object" states="active" class="btn-danger" groups="berit_loan_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,approved,disbursed,active,closed,defaulted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Buttons removed due to missing action definitions -->
                        <!-- <button name="%(berit_loan.action_berit_loan_document)d" type="action" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="document_ids" widget="statinfo" string="Documents"/>
                        </button>
                        <button name="%(berit_loan.action_berit_repayment_schedule)d" type="action" class="oe_stat_button" icon="fa-calendar">
                            <field name="repayment_ids" widget="statinfo" string="Repayments"/>
                        </button>
                        <button name="%(berit_loan.action_berit_collateral)d" type="action" class="oe_stat_button" icon="fa-home">
                            <field name="collateral_ids" widget="statinfo" string="Collaterals"/>
                        </button>
                        <button name="%(berit_loan.action_berit_guarantor)d" type="action" class="oe_stat_button" icon="fa-users">
                            <field name="guarantor_ids" widget="statinfo" string="Guarantors"/>
                        </button> -->
                    </div>
                    
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="applicant_id" required="1"/>
                            <field name="portal_application_ref"/>
                            <field name="loan_officer_id"/>
                            <field name="application_date"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="disbursement_date" readonly="1"/>
                            <field name="maturity_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="loan_amount"/>
                            <field name="loan_duration"/>
                            <field name="interest_rate" readonly="1"/>
                            <field name="monthly_repayment" readonly="1"/>
                            <field name="total_repayable" readonly="1"/>
                            <field name="legal_fee" readonly="1"/>
                            <field name="collateral_required" readonly="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Loan Details">
                            <group>
                                <field name="loan_purpose"/>
                                <field name="has_prior_loans" readonly="1"/>
                                <field name="kyc_verified"/>
                                <field name="crb_cleared"/>
                                <field name="guarantor_id"/>
                            </group>
                            <group string="Verification Status">
                                <field name="kyc_verified"/>
                                <field name="crb_cleared"/>
                            </group>
                            <group string="Notes">
                                <field name="notes" nolabel="1"/>
                            </group>
                        </page>
                        
                        <page string="Documents">
                            <field name="document_ids">
                                <tree>
                                    <field name="document_type"/>
                                    <field name="filename"/>
                                    <field name="upload_date"/>
                                    <field name="verified"/>
                                    <field name="verified_by"/>
                                    <field name="file_size"/>
                                    <button name="action_download" string="Download" type="object" icon="fa-download"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="document_type"/>
                                        <field name="file" filename="filename"/>
                                        <field name="filename"/>
                                        <field name="upload_date"/>
                                        <field name="expiry_date"/>
                                        <field name="is_required"/>
                                        <field name="verified"/>
                                        <field name="verified_by"/>
                                        <field name="verified_date"/>
                                        <field name="file_size" readonly="1"/>
                                        <field name="mime_type" readonly="1"/>
                                    </group>
                                    <group string="Notes">
                                        <field name="notes" nolabel="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        
                        <page string="Collaterals">
                            <field name="collateral_ids">
                                <tree>
                                    <field name="collateral_type"/>
                                    <field name="estimated_value"/>
                                    <field name="valuation_date"/>
                                    <field name="is_verified"/>
                                    <field name="verified_by"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="collateral_type"/>
                                        <field name="description"/>
                                        <field name="estimated_value"/>
                                        <field name="valuation_date"/>
                                        <field name="location"/>
                                        <field name="serial_number"/>
                                        <field name="registration_number"/>
                                        <field name="insurance_policy"/>
                                    </group>
                                    <group string="Documents">
                                        <field name="valuation_document" filename="valuation_document_name"/>
                                        <field name="valuation_document_name"/>
                                        <field name="ownership_proof" filename="ownership_proof_name"/>
                                        <field name="ownership_proof_name"/>
                                    </group>
                                    <group string="Verification">
                                        <field name="is_verified"/>
                                        <field name="verified_by"/>
                                        <field name="verified_date"/>
                                    </group>
                                    <group string="Notes">
                                        <field name="notes" nolabel="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        
                        <page string="Guarantors">
                            <field name="guarantor_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                    <field name="is_verified"/>
                                    <field name="verified_by"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="id_number"/>
                                        <field name="phone"/>
                                        <field name="email"/>
                                        <field name="employer_address"/>
                                        <field name="relationship_to_applicant"/>
                                        <field name="occupation"/>
                                        <field name="monthly_income"/>
                                        <field name="years_known"/>
                                    </group>
                                    <group string="Documents">
                                        <field name="guarantee_letter" filename="guarantee_letter_name"/>
                                        <field name="guarantee_letter_name"/>
                                        <field name="bank_statement" filename="bank_statement_name"/>
                                        <field name="bank_statement_name"/>
                                        <field name="id_copy" filename="id_copy_name"/>
                                        <field name="id_copy_name"/>
                                    </group>
                                    <group string="Verification">
                                        <field name="is_verified"/>
                                        <field name="verified_by"/>
                                        <field name="verified_date"/>
                                    </group>
                                    <group string="Notes">
                                        <field name="notes" nolabel="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        
                        <page string="Repayment Schedule">
                            <field name="repayment_ids">
                                <tree>
                                    <field name="due_date"/>
                                    <field name="principal_amount"/>
                                    <field name="interest_amount"/>
                                    <field name="total_due"/>
                                    <field name="amount_paid"/>
                                    <field name="status"/>
                                    <field name="days_overdue"/>
                                    <field name="penalty_amount"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="due_date"/>
                                        <field name="principal_amount"/>
                                        <field name="interest_amount"/>
                                        <field name="total_due"/>
                                        <field name="amount_paid"/>
                                        <field name="payment_date"/>
                                        <field name="status"/>
                                        <field name="days_overdue"/>
                                        <field name="penalty_amount"/>
                                        <field name="payment_method"/>
                                        <field name="payment_reference"/>
                                    </group>
                                    <group string="Notes">
                                        <field name="notes" nolabel="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Loan Application List View -->
    <record id="view_berit_loan_application_tree" model="ir.ui.view">
        <field name="name">berit.loan.application.tree</field>
        <field name="model">berit.loan.application</field>
        <field name="arch" type="xml">
            <tree string="Loan Applications" decoration-success="state == 'approved'" decoration-warning="state == 'under_review'" decoration-danger="state == 'rejected' or state == 'defaulted'" decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="applicant_id"/>
                <field name="loan_amount"/>
                <field name="loan_duration"/>
                <field name="interest_rate"/>
                <field name="monthly_repayment"/>
                <field name="state"/>
                <field name="application_date"/>
                <field name="loan_officer_id"/>
                <field name="kyc_verified"/>
                <field name="crb_cleared"/>
            </tree>
        </field>
    </record>

