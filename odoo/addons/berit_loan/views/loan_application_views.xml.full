    <!-- Loan Application Search View -->
    <record id="view_berit_loan_application_search" model="ir.ui.view">
        <field name="name">berit.loan.application.search</field>
        <field name="model">berit.loan.application</field>
        <field name="arch" type="xml">
            <search string="Loan Applications">
                <field name="name"/>
                <field name="applicant_id"/>
                <field name="portal_application_ref"/>
                <field name="loan_officer_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Under Review" name="under_review" domain="[('state', '=', 'under_review')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Disbursed" name="disbursed" domain="[('state', '=', 'disbursed')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Defaulted" name="defaulted" domain="[('state', '=', 'defaulted')]"/>
                <separator/>
                <filter string="KYC Verified" name="kyc_verified" domain="[('kyc_verified', '=', True)]"/>
                <filter string="CRB Cleared" name="crb_cleared" domain="[('crb_cleared', '=', True)]"/>
                <separator/>
                <filter string="This Month" name="this_month" domain="[('application_date', '>=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')), ('application_date', '&lt;', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last Month" name="last_month" domain="[('application_date', '>=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')), ('application_date', '&lt;', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Year" name="this_year" domain="[('application_date', '>=', (context_today() - relativedelta(day=1, month=1)).strftime('%Y-%m-%d')), ('application_date', '&lt;', (context_today() + relativedelta(day=31, month=12)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Applicant" name="group_applicant" context="{'group_by': 'applicant_id'}"/>
                    <filter string="Loan Officer" name="group_loan_officer" context="{'group_by': 'loan_officer_id'}"/>
                    <filter string="Application Date" name="group_application_date" context="{'group_by': 'application_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Loan Application Action -->
    <record id="action_berit_loan_application" model="ir.actions.act_window">
        <field name="name">Loan Applications</field>
        <field name="res_model">berit.loan.application</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_id" ref="view_berit_loan_application_kanban"/>
        <field name="search_view_id" ref="view_berit_loan_application_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first loan application
            </p>
            <p>
                Use this form to create and manage loan applications for Berit Shalvah Financial Services.
            </p>
        </field>
    </record>

    <!-- Loan Application Form Action -->
    <record id="action_berit_loan_application_form" model="ir.actions.act_window">
        <field name="name">Loan Application</field>
        <field name="res_model">berit.loan.application</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_berit_loan_application_form"/>
        <field name="target">current</field>
    </record>
</odoo>
