<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Repayment Schedule Form View -->
    <record id="view_berit_repayment_schedule_form" model="ir.ui.view">
        <field name="name">berit.repayment.schedule.form</field>
        <field name="model">berit.repayment.schedule</field>
        <field name="arch" type="xml">
            <form string="Repayment Schedule">
                <header>
                    <button name="action_mark_paid" string="Mark Paid" type="object" states="pending,overdue,partially_paid" class="btn-success"/>
                    <button name="send_reminder_email" string="Send Reminder" type="object" states="pending,overdue" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,partially_paid,paid,overdue"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="loan_id" readonly="1"/>
                            <field name="due_date"/>
                            <field name="principal_amount"/>
                            <field name="interest_amount"/>
                            <field name="total_due" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount_paid"/>
                            <field name="payment_date" readonly="1"/>
                            <field name="status"/>
                            <field name="days_overdue" readonly="1"/>
                            <field name="penalty_amount" readonly="1"/>
                        </group>
                    </group>
                    <group string="Payment Details">
                        <field name="payment_method"/>
                        <field name="payment_reference"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Repayment Schedule List View -->
    <record id="view_berit_repayment_schedule_tree" model="ir.ui.view">
        <field name="name">berit.repayment.schedule.tree</field>
        <field name="model">berit.repayment.schedule</field>
        <field name="arch" type="xml">
            <tree string="Repayment Schedule" decoration-success="state == 'paid'" decoration-warning="state == 'overdue'" decoration-info="state == 'partially_paid'">
                <field name="loan_id"/>
                <field name="due_date"/>
                <field name="principal_amount" widget="monetary"/>
                <field name="interest_amount" widget="monetary"/>
                <field name="total_due" widget="monetary"/>
                <field name="amount_paid" widget="monetary"/>
                <field name="status"/>
                <field name="days_overdue"/>
                <field name="penalty_amount" widget="monetary"/>
                <field name="payment_date"/>
                <button name="action_mark_paid" string="Mark Paid" type="object" states="pending,overdue,partially_paid" icon="fa-check"/>
            </tree>
        </field>
    </record>

    <!-- Repayment Schedule Search View -->
    <record id="view_berit_repayment_schedule_search" model="ir.ui.view">
        <field name="name">berit.repayment.schedule.search</field>
        <field name="model">berit.repayment.schedule</field>
        <field name="arch" type="xml">
            <search string="Repayment Schedule">
                <field name="loan_id"/>
                <field name="due_date"/>
                <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <filter string="Overdue" name="overdue" domain="[('state', '=', 'overdue')]"/>
                <filter string="Partially Paid" name="partially_paid" domain="[('state', '=', 'partially_paid')]"/>
                <separator/>
                <filter string="This Month" name="this_month" domain="[('due_date', '>=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')), ('due_date', '&lt;', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                <filter string="Next Month" name="next_month" domain="[('due_date', '>=', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d')), ('due_date', '&lt;', (context_today() + relativedelta(months=2, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Overdue" name="overdue_filter" domain="[('due_date', '&lt;', context_today()), ('state', '=', 'pending')]"/>
                <group expand="0" string="Group By">
                    <filter string="Loan" name="group_loan" context="{'group_by': 'loan_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="Due Date" name="group_due_date" context="{'group_by': 'due_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Repayment Schedule Action -->
    <record id="action_berit_repayment_schedule" model="ir.actions.act_window">
        <field name="name">Repayment Schedule</field>
        <field name="res_model">berit.repayment.schedule</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_berit_repayment_schedule_tree"/>
        <field name="search_view_id" ref="view_berit_repayment_schedule_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No repayment schedules found
            </p>
            <p>
                Repayment schedules are automatically generated when a loan is approved.
            </p>
        </field>
    </record>

    <!-- Active Loans Repayment Schedule Action -->
    <record id="action_berit_repayment_schedule_active" model="ir.actions.act_window">
        <field name="name">Active Loan Repayments</field>
        <field name="res_model">berit.repayment.schedule</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('loan_id.state', '=', 'active')]</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <!-- Overdue Repayments Action -->
    <record id="action_berit_repayment_schedule_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Repayments</field>
        <field name="res_model">berit.repayment.schedule</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'overdue')]</field>
    </record>
</odoo>
