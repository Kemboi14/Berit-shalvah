<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Loan Application Sequence -->
    <record id="sequence_berit_loan_application" model="ir.sequence">
        <field name="name">Berit Loan Application</field>
        <field name="code">berit.loan.application</field>
        <field name="prefix">BERIT/LOAN/</field>
        <field name="padding">4</field>
        <field name="suffix">/2026/</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Loan Agreement Sequence -->
    <record id="sequence_berit_loan_agreement" model="ir.sequence">
        <field name="name">Berit Loan Agreement</field>
        <field name="code">berit.loan.agreement</field>
        <field name="prefix">BERIT/AGR/</field>
        <field name="padding">4</field>
        <field name="suffix">/2026/</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
