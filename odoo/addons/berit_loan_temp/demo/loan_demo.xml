        <field name="employer_address">XYZ Bank, Thika Road, Nairobi</field>
        <field name="relationship_to_applicant">family</field>
        <field name="occupation">Bank Manager</field>
        <field name="monthly_income">150000</field>
        <field name="years_known">10</field>
