<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Loan Application Form View -->
    <record id="view_berit_loan_application_form" model="ir.ui.view">
        <field name="name">berit.loan.application.form</field>
        <field name="model">berit.loan.application</field>
        <field name="arch" type="xml">
            <form string="Loan Application">
                <header>
                    <button
                        name="action_submit"
                        string="Submit"
                        type="object"
                        invisible="state != 'draft'"
                        class="btn-primary"
                    />
                    <button
                        name="action_under_review"
                        string="Start Review"
                        type="object"
                        invisible="state != 'submitted'"
                        class="btn-secondary"
                    />
                    <button
                        name="action_approve"
                        string="Approve"
                        type="object"
                        invisible="state != 'under_review'"
                        class="btn-success"
                        groups="berit_loan_manager"
                    />
                    <button
                        name="action_reject"
                        string="Reject"
                        type="object"
                        invisible="state != 'under_review'"
                        class="btn-danger"
                        groups="berit_loan_manager"
                    />
                    <button
                        name="action_disburse"
                        string="Disburse"
                        type="object"
                        invisible="state != 'approved'"
                        class="btn-primary"
                        groups="berit_loan_manager"
                    />
                    <button
                        name="action_activate"
                        string="Activate"
                        type="object"
                        invisible="state != 'disbursed'"
                        class="btn-primary"
                        groups="berit_loan_manager"
                    />
                    <button
                        name="action_close"
                        string="Close"
                        type="object"
                        invisible="state != 'active'"
                        class="btn-success"
                        groups="berit_loan_manager"
                    />
                    <button
                        name="action_default"
                        string="Mark Defaulted"
                        type="object"
                        invisible="state != 'active'"
                        class="btn-danger"
                        groups="berit_loan_manager"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,submitted,under_review,approved,disbursed,active,closed,defaulted"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1" />
                            <field name="applicant_id" required="1" />
                            <field name="portal_application_ref" />
                            <field name="loan_officer_id" />
                            <field name="application_date" />
                            <field name="approval_date" readonly="1" />
                            <field name="disbursement_date" readonly="1" />
                            <field name="maturity_date" readonly="1" />
                        </group>
                        <group>
                            <field name="loan_amount" />
                            <field name="loan_duration" />
                            <field name="interest_rate" readonly="1" />
                            <field name="monthly_repayment" readonly="1" />
                            <field name="total_repayable" readonly="1" />
                            <field name="legal_fee" readonly="1" />
                            <field name="collateral_required" readonly="1" />
                        </group>
                    </group>
                    <group string="Loan Details">
                        <field name="loan_purpose" />
                        <field name="has_prior_loans" readonly="1" />
                        <field name="kyc_verified" />
                        <field name="crb_cleared" />
                        <field name="guarantor_id" />
                        <field name="notes" />
                    </group>
                    <notebook>
                        <!-- ── Guarantors ─────────────────────────────── -->
                        <page string="Guarantors" name="guarantors">
                            <field name="guarantor_ids" nolabel="1">
                                <list
                                    string="Guarantors"
                                    decoration-success="is_verified"
                                >
                                    <field name="name" />
                                    <field name="id_number" />
                                    <field name="phone" />
                                    <field name="email" />
                                    <field name="relationship_to_applicant" />
                                    <field name="occupation" />
                                    <field name="monthly_income" />
                                    <field name="is_verified" />
                                    <field name="verified_by" />
                                </list>
                                <form string="Guarantor">
                                    <group>
                                        <group>
                                            <field name="name" />
                                            <field name="id_number" />
                                            <field name="phone" />
                                            <field name="email" />
                                            <field
                                                name="relationship_to_applicant"
                                            />
                                            <field name="occupation" />
                                        </group>
                                        <group>
                                            <field name="monthly_income" />
                                            <field name="years_known" />
                                            <field name="employer_address" />
                                            <field name="is_verified" />
                                            <field
                                                name="verified_by"
                                                readonly="1"
                                            />
                                            <field
                                                name="verified_date"
                                                readonly="1"
                                            />
                                        </group>
                                    </group>
                                    <group string="Documents">
                                        <group>
                                            <field
                                                name="guarantee_letter"
                                                filename="guarantee_letter_name"
                                            />
                                            <field
                                                name="guarantee_letter_name"
                                                invisible="1"
                                            />
                                        </group>
                                        <group>
                                            <field
                                                name="id_copy"
                                                filename="id_copy_name"
                                            />
                                            <field
                                                name="id_copy_name"
                                                invisible="1"
                                            />
                                        </group>
                                        <group>
                                            <field
                                                name="bank_statement"
                                                filename="bank_statement_name"
                                            />
                                            <field
                                                name="bank_statement_name"
                                                invisible="1"
                                            />
                                        </group>
                                    </group>
                                    <group string="Notes">
                                        <field name="notes" nolabel="1" />
                                    </group>
                                </form>
                            </field>
                        </page>
                        <!-- ── Collaterals ────────────────────────────── -->
                        <page string="Collaterals" name="collaterals">
                            <field name="collateral_ids" nolabel="1">
                                <list
                                    string="Collaterals"
                                    decoration-success="is_verified"
                                >
                                    <field name="collateral_type" />
                                    <field name="description" />
                                    <field name="estimated_value" />
                                    <field name="valuation_date" />
                                    <field name="location" />
                                    <field name="serial_number" />
                                    <field name="registration_number" />
                                    <field name="is_verified" />
                                    <field name="verified_by" />
                                </list>
                                <form string="Collateral">
                                    <group>
                                        <group>
                                            <field name="collateral_type" />
                                            <field name="description" />
                                            <field name="estimated_value" />
                                            <field name="valuation_date" />
                                        </group>
                                        <group>
                                            <field name="location" />
                                            <field name="serial_number" />
                                            <field name="registration_number" />
                                            <field name="insurance_policy" />
                                            <field name="is_verified" />
                                            <field
                                                name="verified_by"
                                                readonly="1"
                                            />
                                            <field
                                                name="verified_date"
                                                readonly="1"
                                            />
                                        </group>
                                    </group>
                                    <group string="Documents">
                                        <group>
                                            <field
                                                name="valuation_document"
                                                filename="valuation_document_name"
                                            />
                                            <field
                                                name="valuation_document_name"
                                                invisible="1"
                                            />
                                        </group>
                                        <group>
                                            <field
                                                name="ownership_proof"
                                                filename="ownership_proof_name"
                                            />
                                            <field
                                                name="ownership_proof_name"
                                                invisible="1"
                                            />
                                        </group>
                                    </group>
                                    <group string="Notes">
                                        <field name="notes" nolabel="1" />
                                    </group>
                                </form>
                            </field>
                        </page>
                        <!-- ── Documents ──────────────────────────────── -->
                        <page string="Documents" name="documents">
                            <field name="document_ids" nolabel="1">
                                <list
                                    string="Documents"
                                    decoration-success="verified"
                                    decoration-warning="expiry_date and expiry_date &lt; context_today()"
                                >
                                    <field name="document_type" />
                                    <field name="filename" />
                                    <field name="upload_date" />
                                    <field name="verified" />
                                    <field name="verified_by" />
                                    <field name="file_size" />
                                    <field name="expiry_date" />
                                    <button
                                        name="action_download"
                                        string="Download"
                                        type="object"
                                        icon="fa-download"
                                    />
                                </list>
                                <form string="Document">
                                    <group>
                                        <group>
                                            <field name="document_type" />
                                            <field
                                                name="file"
                                                filename="filename"
                                            />
                                            <field name="filename" />
                                            <field name="upload_date" />
                                        </group>
                                        <group>
                                            <field name="expiry_date" />
                                            <field name="is_required" />
                                            <field name="verified" />
                                            <field
                                                name="verified_by"
                                                readonly="1"
                                            />
                                            <field
                                                name="verified_date"
                                                readonly="1"
                                            />
                                            <field
                                                name="file_size"
                                                readonly="1"
                                            />
                                            <field
                                                name="mime_type"
                                                readonly="1"
                                            />
                                        </group>
                                    </group>
                                    <group string="Notes">
                                        <field name="notes" nolabel="1" />
                                    </group>
                                </form>
                            </field>
                        </page>
                        <!-- ── Repayment Schedule ─────────────────────── -->
                        <page string="Repayment Schedule" name="repayments">
                            <field name="repayment_ids" nolabel="1">
                                <list
                                    string="Repayment Schedule"
                                    decoration-danger="status == 'overdue'"
                                    decoration-success="status == 'paid'"
                                    decoration-warning="status == 'partially_paid'"
                                >
                                    <field name="due_date" />
                                    <field name="principal_amount" />
                                    <field name="interest_amount" />
                                    <field name="total_due" />
                                    <field name="amount_paid" />
                                    <field name="payment_date" />
                                    <field name="status" />
                                    <field name="days_overdue" />
                                    <field name="penalty_amount" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <!-- Loan Application List View -->
    <record id="view_berit_loan_application_tree" model="ir.ui.view">
        <field name="name">berit.loan.application.tree</field>
        <field name="model">berit.loan.application</field>
        <field name="arch" type="xml">
            <list
                string="Loan Applications"
                decoration-success="state == 'approved'"
                decoration-warning="state == 'under_review'"
                decoration-danger="state == 'rejected' or state == 'defaulted'"
                decoration-muted="state == 'closed'"
            >
                <field name="name" />
                <field name="applicant_id" />
                <field name="loan_amount" />
                <field name="loan_duration" />
                <field name="interest_rate" />
                <field name="monthly_repayment" />
                <field name="state" />
                <field name="application_date" />
                <field name="loan_officer_id" />
                <field name="kyc_verified" />
                <field name="crb_cleared" />
            </list>
        </field>
    </record>

    <!-- Loan Application Action -->
    <record id="action_berit_loan_application" model="ir.actions.act_window">
        <field name="name">Loan Applications</field>
        <field name="res_model">berit.loan.application</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first loan application
            </p>
            <p>
                Use this form to create and manage loan applications for Berit Shalvah Financial Services.
            </p>
        </field>
    </record>

    <!-- Loan Application Form Action -->
    <record
        id="action_berit_loan_application_form"
        model="ir.actions.act_window"
    >
        <field name="name">Loan Application</field>
        <field name="res_model">berit.loan.application</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_berit_loan_application_form" />
        <field name="target">current</field>
    </record>
</odoo>
