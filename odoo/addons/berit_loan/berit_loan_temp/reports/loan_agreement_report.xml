<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_loan_agreement_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context({'lang': o.applicant_id.lang})"/>
            <div class="page">
                <!-- Header -->
                <div style="text-align: center; margin-bottom: 30px;">
                    <h1 style="color: #1B3A6B; font-size: 24px; font-weight: bold;">BERIT SHALVAH FINANCIAL SERVICES LTD</h1>
                    <h2 style="color: #2E6DA4; font-size: 18px;">Where Vision Meets Responsible Capital</h2>
                    <p style="font-size: 12px;">Kiambu County, Kenya | Email: beritfinance@gmail.com | Phone: +254-XXX-XXX-XXX</p>
                    <hr style="border: 2px solid #1B3A6B;"/>
                </div>

                <!-- Title -->
                <div style="text-align: center; margin-bottom: 20px;">
                    <h3 style="color: #1B3A6B; font-size: 20px; font-weight: bold;">LOAN AGREEMENT</h3>
                    <p style="font-size: 14px;"><strong>Agreement Number:</strong> <t t-esc="o.name"/></p>
                    <p style="font-size: 14px;"><strong>Date:</strong> <t t-esc="context_today()"/></p>
                </div>

                <!-- Parties -->
                <div style="margin-bottom: 30px;">
                    <h4 style="color: #1B3A6B; font-size: 16px;">PARTIES TO THIS AGREEMENT</h4>
                    <p><strong>LENDER:</strong> Berit Shalvah Financial Services Ltd, a Kenyan-registered Non-Deposit Taking Credit Provider, headquartered in Kiambu County, Kenya.</p>
                    <p><strong>BORROWER:</strong> <t t-esc="o.applicant_id.name"/></p>
                    <p><strong>ID Number:</strong> <t t-esc="o.applicant_id.ref or 'N/A'"/></p>
                    <p><strong>Address:</strong> <t t-esc="o.applicant_id.street or 'N/A'"/></p>
                    <p><strong>Phone:</strong> <t t-esc="o.applicant_id.phone or 'N/A'"/></p>
                    <p><strong>Email:</strong> <t t-esc="o.applicant_id.email or 'N/A'"/></p>
                </div>

                <!-- Loan Details -->
                <div style="margin-bottom: 30px;">
                    <h4 style="color: #1B3A6B; font-size: 16px;">LOAN DETAILS</h4>
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                        <tr style="background-color: #f5f5f5;">
                            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Loan Amount:</td>
                            <td style="padding: 8px; border: 1px solid #ddd;">KES <t t-esc="'{:,.2f}'.format(o.loan_amount)"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Loan Duration:</td>
                            <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="o.loan_duration"/> months</td>
                        </tr>
                        <tr style="background-color: #f5f5f5;">
                            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Interest Rate:</td>
                            <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="o.interest_rate"/>% per month</td>
                        </tr>
                        <tr>
                            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Monthly Repayment:</td>
                            <td style="padding: 8px; border: 1px solid #ddd;">KES <t t-esc="'{:,.2f}'.format(o.monthly_repayment)"/></td>
                        </tr>
                        <tr style="background-color: #f5f5f5;">
                            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Total Repayable:</td>
                            <td style="padding: 8px; border: 1px solid #ddd;">KES <t t-esc="'{:,.2f}'.format(o.total_repayable)"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Legal Fee:</td>
                            <td style="padding: 8px; border: 1px solid #ddd;">KES <t t-esc="'{:,.2f}'.format(o.legal_fee)"/> (2.5% of loan amount)</td>
                        </tr>
                        <tr style="background-color: #f5f5f5;">
                            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Loan Purpose:</td>
                            <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="o.loan_purpose or 'N/A'"/></td>
                        </tr>
                    </table>
                </div>

                <!-- Repayment Schedule -->
                <div style="margin-bottom: 30px;">
                    <h4 style="color: #1B3A6B; font-size: 16px;">REPAYMENT SCHEDULE</h4>
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                        <thead>
                            <tr style="background-color: #1B3A6B; color: white;">
                                <th style="padding: 8px; border: 1px solid #ddd;">Installment</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Due Date</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Principal</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Interest</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Total Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.repayment_ids.sorted('due_date')" t-as="repayment" t-as-index="index">
                                <tr t-attf-style="background-color: #{'ffffff' if index % 2 == 0 else '#f5f5f5'};">
                                    <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><t t-esc="index + 1"/></td>
                                    <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><t t-esc="repayment.due_date"/></td>
                                    <td style="padding: 8px; border: 1px solid #ddd; text-align: right;">KES <t t-esc="'{:,.2f}'.format(repayment.principal_amount)"/></td>
                                    <td style="padding: 8px; border: 1px solid #ddd; text-align: right;">KES <t t-esc="'{:,.2f}'.format(repayment.interest_amount)"/></td>
                                    <td style="padding: 8px; border: 1px solid #ddd; text-align: right;">KES <t t-esc="'{:,.2f}'.format(repayment.total_due)"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Collateral Details -->
                <div style="margin-bottom: 30px;">
                    <h4 style="color: #1B3A6B; font-size: 16px;">COLLATERAL DETAILS</h4>
                    <t t-if="o.collateral_ids">
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                            <thead>
                                <tr style="background-color: #1B3A6B; color: white;">
                                    <th style="padding: 8px; border: 1px solid #ddd;">Type</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;">Description</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;">Estimated Value</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;">Verified</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.collateral_ids" t-as="collateral">
                                    <tr>
                                        <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="collateral.collateral_type"/></td>
                                        <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="collateral.description"/></td>
                                        <td style="padding: 8px; border: 1px solid #ddd; text-align: right;">KES <t t-esc="'{:,.2f}'.format(collateral.estimated_value)"/></td>
                                        <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><t t-esc="'Yes' if collateral.is_verified else 'No'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <p>No collateral specified for this loan.</p>
                    </t>
                    <p><strong>Required Collateral Value:</strong> KES <t t-esc="'{:,.2f}'.format(o.collateral_required)"/> (1.5× loan amount)</p>
                </div>

                <!-- Guarantor Details -->
                <div style="margin-bottom: 30px;">
                    <h4 style="color: #1B3A6B; font-size: 16px;">GUARANTOR DETAILS</h4>
                    <t t-if="o.guarantor_ids">
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                            <thead>
                                <tr style="background-color: #1B3A6B; color: white;">
                                    <th style="padding: 8px; border: 1px solid #ddd;">Name</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;">ID Number</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;">Phone</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;">Relationship</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;">Verified</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.guarantor_ids" t-as="guarantor">
                                    <tr>
                                        <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="guarantor.name"/></td>
                                        <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="guarantor.id_number"/></td>
                                        <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="guarantor.phone"/></td>
                                        <td style="padding: 8px; border: 1px solid #ddd;"><t t-esc="guarantor.relationship_to_applicant or 'N/A'"/></td>
                                        <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><t t-esc="'Yes' if guarantor.is_verified else 'No'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <p>No guarantor specified for this loan.</p>
                    </t>
                </div>

                <!-- Terms and Conditions -->
                <div style="margin-bottom: 30px;">
                    <h4 style="color: #1B3A6B; font-size: 16px;">TERMS AND CONDITIONS</h4>
                    <ol style="font-size: 12px; line-height: 1.5;">
                        <li>This loan agreement is governed by the laws of Kenya.</li>
                        <li>The borrower agrees to repay the loan amount plus interest as per the repayment schedule above.</li>
                        <li>Monthly repayments are due on the specified dates without exception.</li>
                        <li>Late payments will incur a penalty of 1% per day on the overdue amount.</li>
                        <li>The collateral provided will be seized if the loan defaults for more than 30 days.</li>
                        <li>The guarantor is jointly and severally liable for the loan repayment.</li>
                        <li>Any changes to this agreement must be made in writing and signed by both parties.</li>
                        <li>The borrower confirms that all information provided is true and accurate.</li>
                        <li>The borrower has read and understood all terms and conditions herein.</li>
                        <li>This agreement constitutes the entire understanding between the parties.</li>
                    </ol>
                </div>

                <!-- Signature Blocks -->
                <div style="margin-top: 50px;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr>
                            <td style="width: 50%; padding: 20px; border: 1px solid #ddd; vertical-align: top;">
                                <p style="font-size: 12px; margin-bottom: 40px;"><strong>BORROWER'S SIGNATURE</strong></p>
                                <p style="font-size: 12px;">Name: <t t-esc="o.applicant_id.name"/></p>
                                <p style="font-size: 12px;">Date: _________________</p>
                                <p style="font-size: 12px;">Signature: _________________</p>
                            </td>
                            <td style="width: 50%; padding: 20px; border: 1px solid #ddd; vertical-align: top;">
                                <p style="font-size: 12px; margin-bottom: 40px;"><strong>GUARANTOR'S SIGNATURE</strong></p>
                                <t t-if="o.guarantor_ids and o.guarantor_ids[0]">
                                    <p style="font-size: 12px;">Name: <t t-esc="o.guarantor_ids[0].name"/></p>
                                </t>
                                <t t-else="">
                                    <p style="font-size: 12px;">Name: _________________</p>
                                </t>
                                <p style="font-size: 12px;">Date: _________________</p>
                                <p style="font-size: 12px;">Signature: _________________</p>
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%; padding: 20px; border: 1px solid #ddd; vertical-align: top;">
                                <p style="font-size: 12px; margin-bottom: 40px;"><strong>FINANCE OFFICER</strong></p>
                                <p style="font-size: 12px;">Name: _________________</p>
                                <p style="font-size: 12px;">Date: _________________</p>
                                <p style="font-size: 12px;">Signature: _________________</p>
                            </td>
                            <td style="width: 50%; padding: 20px; border: 1px solid #ddd; vertical-align: top;">
                                <p style="font-size: 12px; margin-bottom: 40px;"><strong>DIRECTOR</strong></p>
                                <p style="font-size: 12px;">Name: _________________</p>
                                <p style="font-size: 12px;">Date: _________________</p>
                                <p style="font-size: 12px;">Signature: _________________</p>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- Footer -->
                <div style="text-align: center; margin-top: 50px; font-size: 10px; color: #666;">
                    <p>BERIT SHALVAH FINANCIAL SERVICES LTD | Integrity. Access. Growth.</p>
                    <p>This document is electronically generated and valid without physical signature when approved through the system.</p>
                </div>
            </div>
        </t>
    </template>

    <report id="report_loan_agreement"
            string="Loan Agreement"
            model="berit.loan.application"
            report_type="qweb-pdf"
            name="berit_loan.report_loan_agreement_document"
            file="berit_loan.report_loan_agreement_document"
            print_report_name="'Loan Agreement - %s' % (object.name)"/>
</odoo>
