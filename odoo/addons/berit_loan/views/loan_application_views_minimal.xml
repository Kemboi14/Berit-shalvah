<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Loan Application Form View -->
    <record id="view_berit_loan_application_form" model="ir.ui.view">
        <field name="name">berit.loan.application.form</field>
        <field name="model">berit.loan.application</field>
        <field name="arch" type="xml">
            <form string="Loan Application">
                <header>
                    <button name="action_submit" string="Submit" type="object" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_under_review" string="Start Review" type="object" invisible="state != 'submitted'" class="btn-secondary"/>
                    <button name="action_approve" string="Approve" type="object" invisible="state != 'under_review'" class="btn-success" groups="berit_loan_manager"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'under_review'" class="btn-danger" groups="berit_loan_manager"/>
                    <button name="action_disburse" string="Disburse" type="object" invisible="state != 'approved'" class="btn-primary" groups="berit_loan_manager"/>
                    <button name="action_activate" string="Activate" type="object" invisible="state != 'disbursed'" class="btn-primary" groups="berit_loan_manager"/>
                    <button name="action_close" string="Close" type="object" invisible="state != 'active'" class="btn-success" groups="berit_loan_manager"/>
                    <button name="action_default" string="Mark Defaulted" type="object" invisible="state != 'active'" class="btn-danger" groups="berit_loan_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,approved,disbursed,active,closed,defaulted"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="applicant_id" required="1"/>
                            <field name="portal_application_ref"/>
                            <field name="loan_officer_id"/>
                            <field name="application_date"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="disbursement_date" readonly="1"/>
                            <field name="maturity_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="loan_amount"/>
                            <field name="loan_duration"/>
                            <field name="interest_rate" readonly="1"/>
                            <field name="monthly_repayment" readonly="1"/>
                            <field name="total_repayable" readonly="1"/>
                            <field name="legal_fee" readonly="1"/>
                            <field name="collateral_required" readonly="1"/>
                        </group>
                    </group>
                    <group string="Loan Details">
                        <field name="loan_purpose"/>
                        <field name="has_prior_loans" readonly="1"/>
                        <field name="kyc_verified"/>
                        <field name="crb_cleared"/>
                        <field name="guarantor_id"/>
                        <field name="notes"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Loan Application List View -->
    <record id="view_berit_loan_application_tree" model="ir.ui.view">
        <field name="name">berit.loan.application.tree</field>
        <field name="model">berit.loan.application</field>
        <field name="arch" type="xml">
            <list string="Loan Applications" decoration-success="state == 'approved'" decoration-warning="state == 'under_review'" decoration-danger="state == 'rejected' or state == 'defaulted'" decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="applicant_id"/>
                <field name="loan_amount"/>
                <field name="loan_duration"/>
                <field name="interest_rate"/>
                <field name="monthly_repayment"/>
                <field name="state"/>
                <field name="application_date"/>
                <field name="loan_officer_id"/>
                <field name="kyc_verified"/>
                <field name="crb_cleared"/>
            </list>
        </field>
    </record>

    <!-- Loan Application Action -->
    <record id="action_berit_loan_application" model="ir.actions.act_window">
        <field name="name">Loan Applications</field>
        <field name="res_model">berit.loan.application</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first loan application
            </p>
            <p>
                Use this form to create and manage loan applications for Berit Shalvah Financial Services.
            </p>
        </field>
    </record>
</odoo>
