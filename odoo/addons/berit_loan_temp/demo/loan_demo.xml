        <field name="is_required" eval="True"/>
        <field name="expiry_date" eval="(datetime.now() + timedelta(days="345")).strftime('%Y-%m-%d')"/>
    </record>

    <!-- Demo Repayment Schedules -->
    <record id="demo_repayment_1_1" model="berit.repayment.schedule">
        <field name="loan_id" ref="demo_loan_application_1"/>
        <field name="due_date" eval="(datetime.now() + timedelta(days="22")).strftime('%Y-%m-%d')"/>
        <field name="principal_amount" eval="25000"/>
        <field name="interest_amount" eval="2625"/>
        <field name="total_due" eval="27625"/>
