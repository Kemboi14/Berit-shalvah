    </record>

    <!-- Demo Documents -->
    <record id="demo_document_1" model="berit.loan.document">
        <field name="loan_id" ref="demo_loan_application_1"/>
        <field name="document_type">id</field>
        <field name="filename">John_Mwangi_ID_Copy.pdf</field>
        <field name="upload_date" eval="(datetime.now() - timedelta(days="15")).strftime('%Y-%m-%d')"/>
        <field name="verified" eval="True"/>
        <field name="verified_by" ref="base.user_admin"/>
        <field name="verified_date" eval="(datetime.now() - timedelta(days="14")).strftime('%Y-%m-%d')"/>
        <field name="is_required" eval="True"/>
    </record>

    <record id="demo_document_2" model="berit.loan.document">
        <field name="loan_id" ref="demo_loan_application_1"/>
        <field name="document_type">kra_pin</field>
        <field name="filename">John_Mwangi_KRA_PIN.pdf</field>
        <field name="upload_date" eval="(datetime.now() - timedelta(days="15")).strftime('%Y-%m-%d')"/>
        <field name="verified" eval="True"/>
